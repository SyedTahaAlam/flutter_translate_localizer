{
  "@@locale": "en",

  "itemCount": "{count, plural, =0{No items} =1{1 item} other{{count} items}}",
  "@itemCount": {
    "description": "Shows number of items",
    "placeholders": {
      "count": {
        "type": "int",
        "example": 5
      }
    }
  },

  "genderMessage": "{gender, select, male{He is online} female{She is online} other{They are online}}",
  "@genderMessage": {
    "description": "Gender-based message",
    "placeholders": {
      "gender": {
        "type": "String",
        "example": "male"
      }
    }
  },

  "nestedExample": "{gender, select, male{{count, plural, =0{He has no messages} =1{He has 1 message} other{He has {count} messages}}} female{{count, plural, =0{She has no messages} =1{She has 1 message} other{She has {count} messages}}} other{{count, plural, =0{They have no messages} =1{They have 1 message} other{They have {count} messages}}}}",
  "@nestedExample": {
    "description": "Nested select and plural example",
    "placeholders": {
      "gender": {
        "type": "String"
      },
      "count": {
        "type": "int"
      }
    }
  },

  "dateExample": "Today is {date}",
  "@dateExample": {
    "description": "Formatted date example",
    "placeholders": {
      "date": {
        "type": "DateTime",
        "format": "yMMMMd",
        "example": "January 1, 2025"
      }
    }
  },

  "timeExample": "Current time: {time}",
  "@timeExample": {
    "description": "Formatted time",
    "placeholders": {
      "time": {
        "type": "DateTime",
        "format": "jm",
        "example": "5:08 PM"
      }
    }
  },

  "numberExample": "Value: {value}",
  "@numberExample": {
    "description": "Formatted number",
    "placeholders": {
      "value": {
        "type": "double",
        "format": "decimalPattern",
        "example": "1,234.56"
      }
    }
  },

  "currencyExample": "Price: {price}",
  "@currencyExample": {
    "description": "Currency formatted value",
    "placeholders": {
      "price": {
        "type": "double",
        "format": "currency",
        "example": "99.99"
      }
    }
  },

  "escapedText": "This is an escaped '{text}' example",
  "@escapedText": {
    "description": "Escaping special characters",
    "placeholders": {
      "text": {
        "type": "String"
      }
    }
  },

  "multiLine": "This is line one.\nThis is line two.",
  "@multiLine": {
    "description": "Multi-line text example"
  }
}